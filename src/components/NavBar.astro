---
const base = import.meta.env.BASE_URL;
const path = Astro.url.pathname;

const links = [
  { href: base + '/all', label: 'Bài viết' },
  { href: base + '/tutorial', label: 'Hướng dẫn' },
  { href: base + '/projects', label: 'Dự án' },
];

function isActive(href: string) {
  if (href === base + '/all') return path.startsWith(base + '/all');
  if (href === base + '/tutorial') return path.startsWith(base + '/tutorial');
  if (href === base + '/projects') return path === href;
  return false;
}
---

<nav class="sticky top-0 z-10 bg-bg/80 backdrop-blur-xs border-b border-border" data-nav>
  <div class="mx-auto max-w-2xl px-6">
    <div class="flex items-center justify-between h-14">
      <a
        href={base}
        class="font-semibold text-fg hover:text-primary transition-colors"
      >
        Nghia Hoang
      </a>

      <div class="flex items-center md:hidden">
        <div class="flex items-center gap-2 mr-1">
          <a
            href="https://github.com/nghiaxh"
            target="_blank"
            rel="noopener"
            class="text-fg hover:text-primary transition-colors p-2"
            aria-label="GitHub"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/nghiaxh/"
            target="_blank"
            rel="noopener"
            class="text-fg hover:text-primary transition-colors p-2"
            aria-label="LinkedIn"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
              <rect width="4" height="12" x="2" y="9" />
              <circle cx="4" cy="4" r="2" />
            </svg>
          </a>
        </div>
        <button
          class="text-fg hover:text-primary transition-colors p-2"
          aria-label="Menu"
          data-nav-toggle
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-nav-icon>
            <line x1="3" x2="21" y1="6" y2="6" />
            <line x1="3" x2="21" y1="12" y2="12" />
            <line x1="3" x2="21" y1="18" y2="18" />
          </svg>
        </button>
      </div>

      <div class="hidden md:flex items-center gap-6" data-nav-menu>
        {links.map(link => (
          <a
            href={link.href}
            class={[
              'text-sm transition-colors',
              isActive(link.href) ? 'text-primary' : 'text-fg hover:text-primary',
            ].join(' ')}
          >
            {link.label}
          </a>
        ))}
        <div class="flex items-center gap-3">
          <a
            href="https://github.com/nghiaxh"
            target="_blank"
            rel="noopener"
            class="text-fg hover:text-primary transition-colors"
            aria-label="GitHub"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/nghiaxh/"
            target="_blank"
            rel="noopener"
            class="text-fg hover:text-primary transition-colors"
            aria-label="LinkedIn"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
              <rect width="4" height="12" x="2" y="9" />
              <circle cx="4" cy="4" r="2" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="md:hidden overflow-hidden transition-all duration-300 ease-in-out" style="max-height: 0" data-nav-mobile>
      <div class="border-t border-border py-3 space-y-2">
        {links.map(link => (
          <a
            href={link.href}
            class={[
              'block text-sm py-1.5 transition-colors',
              isActive(link.href) ? 'text-primary' : 'text-fg hover:text-primary',
            ].join(' ')}
            data-nav-link
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </div>
</nav>

<script>
  const nav = document.querySelector('[data-nav]') as HTMLElement | null;
  const toggle = nav?.querySelector('[data-nav-toggle]') as HTMLElement | null;
  const mobile = nav?.querySelector('[data-nav-mobile]') as HTMLElement | null;
  const icon = nav?.querySelector('[data-nav-icon]') as HTMLElement | null;

  function open() {
    if (mobile) {
      mobile.style.setProperty('max-height', mobile.scrollHeight + 'px');
    }
    if (icon) {
      icon.innerHTML = '<line x1="18" x2="6" y1="6" y2="18"/><line x1="6" x2="18" y1="6" y2="18"/>';
    }
    toggle?.setAttribute('aria-expanded', 'true');
  }

  function close() {
    if (mobile) {
      mobile.style.setProperty('max-height', '0');
    }
    if (icon) {
      icon.innerHTML = '<line x1="3" x2="21" y1="6" y2="6"/><line x1="3" x2="21" y1="12" y2="12"/><line x1="3" x2="21" y1="18" y2="18"/>';
    }
    toggle?.setAttribute('aria-expanded', 'false');
  }

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    isOpen ? close() : open();
  });

  nav?.querySelectorAll('[data-nav-link]').forEach(link => {
    link.addEventListener('click', close);
  });

  document.addEventListener('click', (e) => {
    const target = e.target as Node | null;
    if (!nav?.contains(target) && toggle?.getAttribute('aria-expanded') === 'true') {
      close();
    }
  });
</script>
