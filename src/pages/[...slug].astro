---
import BaseLayout from '../layouts/BaseLayout.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings: renderedHeadings } = await render(post);
const base = import.meta.env.BASE_URL;

const wordCount = post.body ? post.body.trim().split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const headings = renderedHeadings
  .filter(h => h.depth >= 1 && h.depth <= 3)
  .map(h => ({ level: h.depth, text: h.text, id: h.slug }));
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <article>
    <p class="mb-8 text-sm">
      <a href={base} class="hover:text-fg hover:underline transition-colors">Quay lại</a>
    </p>

    <header class="mb-8">
      <h1 class="text-3xl font-bold  text-fg leading-tight">{post.data.title}</h1>
      <div class="mt-3 flex flex-wrap gap-x-2 text-sm text-fg">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('vi-VN', {
            year: 'numeric', month: 'short', day: 'numeric',
          })}
        </time>
        <span aria-hidden="true">&bull;</span>
        <span>{readingTime} phút</span>
        <span aria-hidden="true">&bull;</span>
        <span>{wordCount} từ</span>
        {post.data.tags && post.data.tags.length > 0 && (
          <>
            <span aria-hidden="true">&bull;</span>
            <span class="flex gap-2">
              {post.data.tags.map(tag => (
                <span>#{tag}</span>
              ))}
            </span>
          </>
        )}
      </div>
    </header>

    {post.data.coverImage && (
      <img
        src={post.data.coverImage}
        alt=""
        class="w-full rounded-lg mb-10"
        loading="eager"
      />
    )}

    {headings.length > 0 && (
      <aside class="hidden lg:block fixed top-32 right-[max(calc(50%-21rem-14rem),1.5rem)] w-44">
        <nav class="text-xs space-y-0.5 border-l border-border pl-3">
          <p class="text-sm font-bold text-fg mb-2 uppercase">Mục lục</p>
          {headings.map(h => (
            <a
              href={`#${h.id}`}
              class={`block leading-relaxed hover:text-fg hover:underline transition-colors ${h.level === 1 ? 'font-bold' : ''} ${h.level === 2 ? 'pl-3' : ''} ${h.level === 3 ? 'pl-5' : ''}`}
            >
              {h.text}
            </a>
          ))}
        </nav>
      </aside>
    )}
    <div class="prose prose-neutral max-w-none prose-invert">
      <Content />
    </div>
  </article>

  <RelatedPosts currentPost={post} />

</BaseLayout>
