---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const totalPages = Math.ceil(posts.length / 5);
  if (totalPages <= 1) return [];
  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
  }));
}

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const currentPage = parseInt(Astro.params.page);
const totalPages = Math.ceil(allPosts.length / 5);
const start = (currentPage - 1) * 5;
const pagePosts = allPosts.slice(start, start + 5);

const groupedByYear: Record<number, typeof pagePosts> = {};
const base = import.meta.env.BASE_URL;
for (const post of pagePosts) {
  const year = post.data.pubDate.getFullYear();
  if (!groupedByYear[year]) groupedByYear[year] = [];
  groupedByYear[year].push(post);
}
---

<BaseLayout title="Bài viết - Trang {currentPage}" description="Tất cả bài viết">
  <h1 class="text-3xl font-bold mb-8 text-fg">Bài viết</h1>

  {Object.entries(groupedByYear).reverse().map(([year, yearPosts]) => (
    <div class="mb-10">
      <h2 class="text-base font-bold mb-4 text-fg">{year}</h2>
      <ul class="space-y-3">
        {yearPosts.map(post => (
          <li>
            <a
              href={base + '/' + post.id}
              class="font-medium text-fg no-underline hover:text-fg transition-colors"
            >
              {post.data.title}
            </a>
            <p class="text-sm text-fg mt-0.5">{post.data.description}</p>
          </li>
        ))}
      </ul>
    </div>
  ))}

  {totalPages > 1 && (
    <nav class="flex justify-between items-center mt-12 pt-8 border-t border-border">
      <a
        href={currentPage === 2 ? base + '/all' : base + '/all/' + (currentPage - 1)}
        class="text-sm hover:underline hover:text-fg transition-colors"
      >
        &larr; Trang trước
      </a>
      <span class="text-sm text-fg">{currentPage} / {totalPages}</span>
      {currentPage < totalPages ? (
        <a
          href={base + '/all/' + (currentPage + 1)}
          class="text-sm hover:underline hover:text-fg transition-colors"
        >
          Trang sau &rarr;
        </a>
      ) : (
        <span />
      )}
    </nav>
  )}
</BaseLayout>
