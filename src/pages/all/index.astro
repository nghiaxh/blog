---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const POSTS_PER_PAGE = 5;
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const pagePosts = allPosts.slice(0, POSTS_PER_PAGE);

const groupedByYear: Record<number, typeof pagePosts> = {};
const base = import.meta.env.BASE_URL;
for (const post of pagePosts) {
  const year = post.data.pubDate.getFullYear();
  if (!groupedByYear[year]) groupedByYear[year] = [];
  groupedByYear[year].push(post);
}
---

<BaseLayout title="Bài viết" description="Tất cả bài viết">
  <h1 class="text-3xl font-bold mb-8 text-fg">Bài viết</h1>

  {Object.entries(groupedByYear).reverse().map(([year, yearPosts]) => (
    <div class="mb-10">
      <h2 class="text-base font-bold mb-4 text-fg">{year}</h2>
      <ul class="space-y-3">
        {yearPosts.map(post => (
          <li>
            <a
              href={base + '/' + post.id}
              class="font-medium text-fg no-underline hover:text-fg transition-colors"
            >
              {post.data.title}
            </a>
            <p class="text-sm text-fg mt-0.5">{post.data.description}</p>
          </li>
        ))}
      </ul>
    </div>
  ))}

  {totalPages > 1 && (
    <nav class="flex justify-between items-center mt-12 pt-8 border-t border-border">
      <span />
      <span class="text-sm text-fg">1 / {totalPages}</span>
      <a
        href={base + '/all/2'}
        class="text-sm text-primary hover:underline hover:text-fg transition-colors"
      >
        Trang sau &rarr;
      </a>
    </nav>
  )}
</BaseLayout>
