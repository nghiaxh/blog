---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

const groups: Record<string, typeof allProjects> = {};
for (const p of allProjects) {
  const label = p.data.status;
  if (!groups[label]) groups[label] = [];
  groups[label].push(p);
}

const statusLabels: Record<string, string> = {
  active: 'Đang hoạt động',
  participated: 'Đã tham gia',
  archived: 'Đã ngưng',
};

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Dự án" description="Các dự án của tôi">
  <h1 class="text-3xl font-bold mb-8 text-fg">Dự án</h1>

  {Object.entries(statusLabels).map(([key, label]) => {
    const items = groups[key];
    if (!items) return null;
    return (
      <section class="mb-10">
        <h2 class="text-lg font-semibold mb-4 text-fg">{label}</h2>
        <ul class="space-y-3">
          {items.map(p => (
            <li>
              <h3 class="font-medium text-fg">{p.data.title}</h3>
              <p class="text-sm text-fg/60 mt-0.5">{p.data.description}</p>
            </li>
          ))}
        </ul>
      </section>
    );
  })}
</BaseLayout>
