---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Dự án" description="Các dự án của tôi">
  <h1 class="text-3xl font-bold  mb-8 text-fg">Dự án</h1>

  <section class="mb-10">
    <h2 class="text-lg font-semibold mb-4">Đang hoạt động</h2>
    <ul class="space-y-3">
      <li>
      <h3 class="font-medium hover:text-fg transition-colors">Quizzy</h3>
        <p class="text-sm text-fg/60 mt-0.5">Ứng dụng tạo và học trắc nghiệm đơn giản.</p>
      </li>
      <li>
        <h3 class="font-medium hover:text-fg transition-colors">Learn TOEIC</h3>
        <p class="text-sm text-fg/60 mt-0.5">Ứng dụng ôn tập và mô phỏng thi TOEIC.</p>
      </li>
      <li>
        <h3 class="font-medium hover:text-fg transition-colors">Tên dự án 3</h3>
        <p class="text-sm text-fg/60 mt-0.5">Mô tả ngắn về dự án này.</p>
      </li>
    </ul>
  </section>

  <section class="mb-10">
    <h2 class="text-lg font-semibold mb-4 text-fg">Đã tham gia</h2>
    <ul class="space-y-3">
      <li>
        <span class="font-medium text-fg">Custom Project Manager</span>
        <p class="text-sm text-fg/60 mt-0.5">Ứng dụng quản lý dự án</p>
      </li>
    </ul>
  </section>

  <section class="mb-10">
    <h2 class="text-lg font-semibold mb-4 text-fg">Đã ngưng</h2>
    <ul class="space-y-3">
      <li>
        <span class="font-medium text-fg">Ebookshelf</span>
        <p class="text-sm text-fg/60 mt-0.5">Ứng dụng quản lý thư viện</p>
      </li>
      <li>
        <span class="font-medium text-fg">Euler Cycle</span>
        <p class="text-sm text-fg/60 mt-0.5">Ứng dụng mô phỏng lý thuyết đồ thị</p>
      </li>
    </ul>
  </section>
</BaseLayout>
