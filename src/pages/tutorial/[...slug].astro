---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const tutorials = await getCollection('tutorial', ({ data }) => !data.draft);
  return tutorials.map(t => ({
    params: { slug: t.id },
    props: { tutorial: t },
  }));
}

const { tutorial } = Astro.props;
const { Content, headings: renderedHeadings } = await render(tutorial);
const base = import.meta.env.BASE_URL;
const category = tutorial.data.category ?? tutorial.id.split('/')[0];

const headings = renderedHeadings
  .filter(h => h.depth >= 1 && h.depth <= 3)
  .map(h => ({ level: h.depth, text: h.text, id: h.slug }));
---

<BaseLayout title={tutorial.data.title} description={tutorial.data.description}>
  <article>
    <p class="mb-8 text-sm">
      <a href={base + '/tutorial'} class="hover:text-fg hover:underline transition-colors">Quay lại</a>
    </p>

    <header class="mb-8">
      <p class="text-xs text-fg uppercase mb-1">{category}</p>
      <h1 class="text-3xl font-bold text-fg leading-tight">{tutorial.data.title}</h1>
      <div class="mt-3 flex flex-wrap gap-x-2 text-sm text-fg">
        <time datetime={tutorial.data.pubDate.toISOString()}>
          {tutorial.data.pubDate.toLocaleDateString('vi-VN', {
            year: 'numeric', month: 'short', day: 'numeric',
          })}
        </time>
        {tutorial.data.tags && tutorial.data.tags.length > 0 && (
          <>
            <span aria-hidden="true">&bull;</span>
            <span class="flex gap-2">
              {tutorial.data.tags.map(tag => <span>#{tag}</span>)}
            </span>
          </>
        )}
      </div>
    </header>

    {tutorial.data.coverImage && (
      <img
        src={tutorial.data.coverImage}
        alt=""
        class="w-full rounded-lg mb-10"
        loading="eager"
      />
    )}

    <TableOfContents headings={headings} />
    <div class="prose prose-neutral max-w-none prose-invert">
      <Content />
    </div>
  </article>
</BaseLayout>
